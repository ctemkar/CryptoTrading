# ============================================================
# Crypto Master Engine — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ---- Gemini Exchange API (REQUIRED) ----
# Get your API keys from https://exchange.gemini.com/settings/api
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_SECRET=your_gemini_api_secret

# ---- Supabase (OPTIONAL) ----
# Supabase is used for persistent state (positions, trades, equity).
# The engine works perfectly fine WITHOUT Supabase — it just won't
# persist state across restarts. Great for testing without Supabase.
# Get your credentials from https://supabase.com/dashboard
SUPABASE_URL=
SUPABASE_KEY=

# ---- Trading Thresholds (OPTIONAL — defaults shown) ----
# Lower = more aggressive trading, Higher = more conservative
# BEARISH_THRESHOLD=58
# BULLISH_THRESHOLD=58
# TRADE_SIZE_USD=50.0
# CYCLE_INTERVAL_MINUTES=15
